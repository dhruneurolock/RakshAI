# RakshAI Production Configuration - All Services Enabled
# Uses PostgreSQL, Redis, Neo4j, Ollama, MinIO

DEBUG=false
ENVIRONMENT=production
SECRET_KEY=your-production-secret-key-change-this

# Database - PostgreSQL (Production)
DATABASE_URL=postgresql://rakshaiuser:root@localhost:5432/rakshaidb

# Feature Flags - ALL ENABLED
REDIS_ENABLED=true
CELERY_ENABLED=true
OLLAMA_ENABLED=true
NEO4J_ENABLED=true
MINIO_ENABLED=true

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Ollama LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=root

# MinIO S3-Compatible Storage Configuration
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rakshaidb
MINIO_SECURE=False

# CORS Configuration (JSON format for list)
CORS_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]'

# Logging
LOG_LEVEL=INFO

# Knowledge Base
KNOWLEDGE_BASE_PATH=./knowledge-base

# Scan Settings
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_SECONDS=3600
MAX_PAYLOADS_PER_TEST=50

# Safety Settings
ENABLE_SAFETY_ENFORCER=true
BLOCK_DESTRUCTIVE_PAYLOADS=true

# Report Settings
REPORT_STORAGE_PATH=./reports
