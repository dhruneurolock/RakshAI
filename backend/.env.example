# Environment Configuration - Local Machine Setup
# Copy this file to .env and update values as needed

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://neuropent:root@localhost:5432/rakshaidb

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# NEO4J CONFIGURATION
# ===========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=root

# ===========================================
# OLLAMA (LLM) CONFIGURATION
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_STRATEGY=llama3.1:8b
LLM_MODEL_ANALYSIS=mistral:7b
LLM_MODEL_EMBEDDING=nomic-embed-text

# ===========================================
# CHROMADB CONFIGURATION
# ===========================================
# Use embedded mode (no separate server needed)
CHROMA_EMBEDDED=true
CHROMA_PATH=D:/RakshAI/chromadb_data

# Or use standalone server
# CHROMA_EMBEDDED=false
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# ===========================================
# MINIO / OBJECT STORAGE CONFIGURATION
# ===========================================
# Option 1: Use MinIO
USE_MINIO=true
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_EVIDENCE=evidence
MINIO_BUCKET_REPORTS=reports

# Option 2: Use local filesystem (recommended for development)
# USE_MINIO=false
# LOCAL_STORAGE_PATH=D:/RakshAI/storage

# ===========================================
# CELERY CONFIGURATION
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# KNOWLEDGE BASE CONFIGURATION
# ===========================================
KNOWLEDGE_BASE_PATH=D:/RakshAI/knowledge-base
KNOWLEDGE_BASE_AUTO_RELOAD=true

# ===========================================
# TOOL SANDBOX CONFIGURATION
# ===========================================
TOOL_SANDBOX_ENABLED=true
TOOL_SANDBOX_TIMEOUT=300
TOOL_SANDBOX_MAX_OUTPUT_SIZE=10485760

# ===========================================
# RATE LIMITING
# ===========================================
MAX_CONCURRENT_SCANS=5
MAX_SCANS_PER_HOUR_PER_TARGET=10
MAX_REQUESTS_PER_SECOND=100

# ===========================================
# ORCHESTRATOR CONFIGURATION
# ===========================================
ORCHESTRATOR_ENABLED=true
SCOPE_VALIDATION_ENABLED=true
GLOBAL_BLACKLIST=google.com,github.com,localhost,127.0.0.1

# ===========================================
# VALIDATION CONFIGURATION
# ===========================================
VALIDATION_REPLAY_COUNT=3
VALIDATION_CONFIDENCE_THRESHOLD=0.85

# ===========================================
# REPORTING CONFIGURATION
# ===========================================
REPORT_TEMPLATE_PATH=D:/RakshAI/backend/app/templates
REPORT_LOGO_PATH=D:/RakshAI/backend/app/static/logo.png

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=rakshaiinfo@example.com

# ===========================================
# MONITORING (Optional)
# ===========================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
