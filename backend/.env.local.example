# RakshAI Local Development Configuration
# Copy this to backend/.env for local development

# Application Mode
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production

# Database (SQLite - local file, no setup required)
DATABASE_URL=sqlite:///./rakshaidb_local.db

# Cache (Disabled - uses in-memory fallback)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Task Queue (Disabled for local development)
CELERY_ENABLED=false

# LLM (Mock mode - simulated responses)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# Graph Database (Disabled - functions mocked)
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687

# Storage (Local file-based)
MINIO_ENABLED=false
STORAGE_TYPE=local
STORAGE_PATH=./storage

# Logging
LOG_LEVEL=DEBUG

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
